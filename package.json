{
  "name": "fides-rp-catalog",
  "version": "1.0.0",
  "description": "FIDES Community Relying Party Catalog - Overview of verifier websites and services that accept verifiable credentials",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "crawl": "tsx src/crawler/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/crawler/index.ts",
    "validate": "ajv validate --spec=draft2020 -c ajv-formats -s schemas/rp-catalog.schema.json -d 'community-catalogs/**/rp-catalog.json'",
    "validate:featured": "ajv validate --spec=draft2020 -c ajv-formats -s schemas/featured.schema.json -d 'data/featured.json'",
    "validate:all": "npm run validate && npm run validate:featured",
    "check-links": "tsx scripts/check-links.ts",
    "import-wp-submissions": "tsx scripts/import-wp-submissions.ts",
    "import-wp-submissions:apply": "tsx scripts/import-wp-submissions.ts --apply",
    "sync-local": "bash scripts/sync-plugin-local.sh",
    "wp-sync:local": "FIDES_CATALOG_SECRET=$(php scripts/read-wp-catalog-secret.php 2>/dev/null) tsx scripts/import-wp-submissions.ts --apply --wp-url http://utrecht-demo.local/wp-json/fides-catalog/v1/export/rp && npm run validate && npm run crawl && npm run sync-local",
    "test": "node --import tsx --test src/import-wp-submissions.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FIDEScommunity/fides-rp-catalog.git"
  },
  "keywords": [
    "verifiable-credentials",
    "relying-party",
    "verifier",
    "ssi",
    "decentralized-identity",
    "openid4vp",
    "fides"
  ],
  "author": "FIDES Community",
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vercel/node": "^3.0.0",
    "ajv-cli": "^5.0.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
